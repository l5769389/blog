---
import { getCollection, render } from 'astro:content';
import { ArrowLeft, ArrowRight } from '@lucide/astro';
import Layout from '../../layouts/Layout.astro';
import {
  formatDateEn,
  formatDateZh,
  formatReadTimeEn,
  formatReadTimeZh,
  getSeriesEntries,
  slugifyTag,
  sortPosts,
} from '../../lib/posts';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('blog'));
  const seriesEntries = getSeriesEntries(posts);
  const seriesByPostId = new Map(
    seriesEntries.flatMap((entry) => entry.posts.map((seriesPost) => [seriesPost.id, entry])),
  );

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, seriesEntry: seriesByPostId.get(post.id) },
  }));
}

const { post, seriesEntry } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const backHref = seriesEntry?.href ?? '/blog/';
const backLabelZh = seriesEntry ? '返回系列' : '返回博客';
const backLabelEn = seriesEntry ? 'Back to series' : 'Back to blog';
const seriesPosts = seriesEntry?.posts ?? [];
const currentSeriesIndex = seriesPosts.findIndex((seriesPost) => seriesPost.id === post.id);
const previousSeriesPost = currentSeriesIndex > 0 ? seriesPosts[currentSeriesIndex - 1] : undefined;
const nextSeriesPost =
  currentSeriesIndex >= 0 && currentSeriesIndex < seriesPosts.length - 1
    ? seriesPosts[currentSeriesIndex + 1]
    : undefined;
let seriesPartIndex = 0;
const seriesNavItems = seriesPosts.map((seriesPost) => {
  const isOverview = seriesPost.data.series?.role === 'overview';
  const partNumber = isOverview ? undefined : ++seriesPartIndex;

  return {
    post: seriesPost,
    labelZh: isOverview ? '总览' : String(partNumber).padStart(2, '0'),
    labelEn: isOverview ? 'Overview' : String(partNumber).padStart(2, '0'),
    isCurrent: seriesPost.id === post.id,
  };
});
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="page-shell article-shell">
    <div class="container article-container">
      <div class="article-lead">
        <a class="back-link" href={backHref}>
          <ArrowLeft size={17} stroke-width={2.2} />
          <span data-i18n-zh={backLabelZh} data-i18n-en={backLabelEn}>{backLabelZh}</span>
        </a>
        <header class="article-header">
          <div class="tag-row">
            {post.data.tags.map((tag) => <a class="tag" href={`/tags/#${slugifyTag(tag)}`}>{tag}</a>)}
          </div>
          <h1>{post.data.title}</h1>
          <p>{post.data.description}</p>
          <div class="article-meta">
            <span
              data-i18n-zh={formatDateZh(post.data.pubDate)}
              data-i18n-en={formatDateEn(post.data.pubDate)}
            >
              {formatDateZh(post.data.pubDate)}
            </span>
            <span
              data-i18n-zh={formatReadTimeZh(post.data.readTime)}
              data-i18n-en={formatReadTimeEn(post.data.readTime)}
            >
              {formatReadTimeZh(post.data.readTime)}
            </span>
          </div>
        </header>
      </div>

      <div class="article-layout">
        <div class="content">
          <Content />
        </div>

        {
          (seriesEntry || tocHeadings.length > 0) && (
            <aside class="toc" aria-label="Table of contents">
              {
                seriesEntry && (
                  <section class="toc-section">
                    <p data-i18n-zh="系列导航" data-i18n-en="Series">系列导航</p>
                    <nav class="series-nav" aria-label="Series navigation">
                      {seriesNavItems.map((item) => (
                        <a
                          class:list={['series-link', { 'series-current': item.isCurrent }]}
                          href={`/blog/${item.post.id}/`}
                          aria-current={item.isCurrent ? 'page' : undefined}
                          title={item.post.data.title}
                        >
                          <span data-i18n-zh={item.labelZh} data-i18n-en={item.labelEn}>
                            {item.labelZh}
                          </span>
                          <strong>{item.post.data.title}</strong>
                        </a>
                      ))}
                    </nav>
                  </section>
                )
              }
              {
                tocHeadings.length > 0 && (
                  <section class="toc-section">
                    <p data-i18n-zh="本文目录" data-i18n-en="Contents">本文目录</p>
                    <nav>
                      {tocHeadings.map((heading) => (
                        <a
                          class={`depth-${heading.depth}`}
                          href={`#${heading.slug}`}
                          data-toc-link={heading.slug}
                          title={heading.text}
                        >
                          {heading.text}
                        </a>
                      ))}
                    </nav>
                  </section>
                )
              }
            </aside>
          )
        }
      </div>

      {
        seriesEntry && (previousSeriesPost || nextSeriesPost) && (
          <nav class="series-pager" aria-label="Series pagination">
            {previousSeriesPost ? (
              <a
                class="pager-card previous"
                href={`/blog/${previousSeriesPost.id}/`}
                title={previousSeriesPost.data.title}
                aria-label={`上一篇：${previousSeriesPost.data.title}`}
              >
                <ArrowLeft size={18} stroke-width={2.2} />
                <strong>{previousSeriesPost.data.title}</strong>
              </a>
            ) : (
              <span class="pager-card placeholder" aria-hidden="true"></span>
            )}
            {nextSeriesPost ? (
              <a
                class="pager-card next"
                href={`/blog/${nextSeriesPost.id}/`}
                title={nextSeriesPost.data.title}
                aria-label={`下一篇：${nextSeriesPost.data.title}`}
              >
                <strong>{nextSeriesPost.data.title}</strong>
                <ArrowRight size={17} stroke-width={2.2} />
              </a>
            ) : (
              <span class="pager-card placeholder" aria-hidden="true"></span>
            )}
          </nav>
        )
      }
    </div>
  </article>
  <script>
    const tocLinks = Array.from(document.querySelectorAll('[data-toc-link]'));
    let suppressScrollSpyUntil = 0;
    let scrollSpySettleTimer;
    let getActiveHeadingId = () => null;
    const tocHeadings = tocLinks
      .map((link) => {
        const id = link.getAttribute('data-toc-link');
        const heading = id ? document.getElementById(id) : null;

        return heading ? { heading, link } : null;
      })
      .filter(Boolean);

    const setActiveTocLink = (id) => {
      tocLinks.forEach((link) => {
        const isActive = link.getAttribute('data-toc-link') === id;
        link.classList.toggle('active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'true');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    tocLinks.forEach((link) => {
      link.addEventListener('click', () => {
        const id = link.getAttribute('data-toc-link');
        if (id) {
          suppressScrollSpyUntil = Date.now() + 520;
          window.clearTimeout(scrollSpySettleTimer);
          setActiveTocLink(id);
          scrollSpySettleTimer = window.setTimeout(() => {
            suppressScrollSpyUntil = 0;
            setActiveTocLink(getActiveHeadingId());
          }, 560);
        }
      });
    });

    if (tocHeadings.length > 0) {
      getActiveHeadingId = () => {
        const marker = 120;
        const current = tocHeadings
          .map(({ heading }) => ({
            id: heading.id,
            top: heading.getBoundingClientRect().top,
          }))
          .filter(({ top }) => top <= marker)
          .sort((a, b) => b.top - a.top)[0];

        return current?.id ?? tocHeadings[0].heading.id;
      };

      let ticking = false;
      const updateActiveByScroll = () => {
        if (Date.now() < suppressScrollSpyUntil) {
          return;
        }

        if (ticking) {
          return;
        }

        ticking = true;
        window.requestAnimationFrame(() => {
          setActiveTocLink(getActiveHeadingId());
          ticking = false;
        });
      };

      const initialId = decodeURIComponent(window.location.hash.replace('#', '')) || getActiveHeadingId();
      setActiveTocLink(initialId);

      window.addEventListener('scroll', updateActiveByScroll, { passive: true });
      window.addEventListener('resize', updateActiveByScroll);
      window.addEventListener('hashchange', () => {
        const id = decodeURIComponent(window.location.hash.replace('#', ''));
        if (id) {
          suppressScrollSpyUntil = Date.now() + 520;
          window.clearTimeout(scrollSpySettleTimer);
          setActiveTocLink(id);
          scrollSpySettleTimer = window.setTimeout(() => {
            suppressScrollSpyUntil = 0;
            updateActiveByScroll();
          }, 560);
        }
      });
    }
  </script>
</Layout>

<style>
  .article-shell {
    background: var(--article-bg);
  }

  .article-container {
    width: min(100% - 40px, 1120px);
  }

  .article-lead {
    max-width: 980px;
    margin-inline: auto;
  }

  .back-link {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    gap: 8px;
    margin-bottom: 36px;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0 14px;
    background: var(--surface-soft);
    color: var(--muted);
    font-weight: 750;
    box-shadow: var(--button-shadow);
  }

  .back-link:hover {
    border-color: var(--line-strong);
    color: var(--accent-strong);
  }

  .article-header {
    max-width: 940px;
    padding-bottom: 34px;
    border-bottom: 1px solid var(--line);
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  h1 {
    margin: 0 0 18px;
    font-size: clamp(2.2rem, 1.55rem + 2.2vw, 3.85rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .article-header p {
    margin: 0;
    color: var(--muted);
    font-size: 1.12rem;
    line-height: 1.75;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    margin-top: 24px;
    color: var(--meta-text);
    font-weight: 650;
  }

  .article-meta span + span::before {
    margin-right: 14px;
    color: var(--meta-divider);
    content: "/";
  }

  .article-layout {
    padding-top: 34px;
  }

  .content {
    max-width: 980px;
    min-width: 0;
    margin-inline: auto;
    color: var(--content-text);
    font-size: 1.08rem;
    line-height: 1.85;
  }

  .content :global(p),
  .content :global(h2),
  .content :global(h3),
  .content :global(ul),
  .content :global(ol),
  .content :global(blockquote) {
    max-width: 900px;
  }

  .content :global(p) {
    margin: 0 0 1.35em;
  }

  .content :global(p:has(img)) {
    max-width: 960px;
    margin: 2rem auto;
  }

  .content :global(a) {
    color: var(--accent-strong);
    font-weight: 700;
  }

  .content :global(h2),
  .content :global(h3) {
    scroll-margin-top: 96px;
  }

  .content :global(h2) {
    margin: 2em 0 0.6em;
    font-size: 1.7rem;
    line-height: 1.2;
  }

  .content :global(h3) {
    margin: 1.75em 0 0.5em;
    font-size: 1.28rem;
    line-height: 1.25;
  }

  .content :global(ul),
  .content :global(ol) {
    padding-left: 1.25rem;
  }

  .content :global(li) {
    margin-bottom: 0.55em;
  }

  .content :global(blockquote) {
    margin: 1.6rem 0;
    border-left: 3px solid var(--accent);
    padding: 0.15rem 0 0.15rem 1rem;
    color: var(--muted);
  }

  .content :global(pre) {
    max-width: 960px;
    margin: 1.8rem auto;
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px 20px;
    background: var(--surface-soft);
    color: var(--content-text);
    font-size: 0.92rem;
    line-height: 1.7;
    box-shadow: var(--shadow-soft);
  }

  .content :global(code) {
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.12rem 0.34rem;
    background: var(--surface-soft);
    color: var(--content-text);
    font-size: 0.92em;
  }

  .content :global(pre code) {
    border: 0;
    padding: 0;
    background: transparent;
    font-size: inherit;
  }

  .content :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow-soft);
  }

  .content :global(video) {
    display: block;
    width: 100%;
    max-width: 960px;
    margin: 2rem auto;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #05080d;
    box-shadow: var(--shadow-soft);
  }

  .content :global(.motion-demo) {
    position: relative;
    display: grid;
    min-height: 220px;
    max-width: 960px;
    place-items: center;
    overflow: hidden;
    margin: 2rem auto;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background:
      radial-gradient(circle at 22% 22%, rgba(137, 146, 255, 0.2), transparent 180px),
      radial-gradient(circle at 78% 72%, rgba(118, 211, 156, 0.14), transparent 180px),
      var(--surface-soft);
    box-shadow: var(--shadow-soft);
  }

  .content :global(.motion-track) {
    position: absolute;
    inset: 0;
  }

  .content :global(.motion-track span) {
    position: absolute;
    top: 50%;
    left: -90px;
    width: 70px;
    height: 3px;
    border-radius: 999px;
    background: var(--accent);
    opacity: 0.78;
    animation: flow-line 3.2s linear infinite;
  }

  .content :global(.motion-track span:nth-child(2)) {
    top: 38%;
    animation-delay: 0.8s;
    opacity: 0.48;
  }

  .content :global(.motion-track span:nth-child(3)) {
    top: 62%;
    animation-delay: 1.6s;
    opacity: 0.58;
  }

  .content :global(.motion-panel) {
    position: relative;
    display: grid;
    gap: 6px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 20px 24px;
    background: color-mix(in srgb, var(--surface) 86%, transparent);
    text-align: center;
  }

  .content :global(.motion-panel strong) {
    color: var(--text);
    font-size: 1.05rem;
  }

  .content :global(.motion-panel small) {
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .content :global(.case-hero),
  .content :global(.capability-map),
  .content :global(.architecture-diagram),
  .content :global(.sequence-diagram),
  .content :global(.state-model),
  .content :global(.pipeline-diagram),
  .content :global(.tradeoff-grid) {
    max-width: 980px;
    margin: 2rem auto;
  }

  .content :global(.case-hero) {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(260px, 0.85fr);
    gap: 24px;
    align-items: stretch;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 26px;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--accent) 10%, transparent), transparent 48%),
      var(--surface-soft);
    box-shadow: var(--shadow-soft);
  }

  .content :global(.case-kicker) {
    display: inline-flex;
    margin-bottom: 10px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .content :global(.case-hero h2) {
    max-width: none;
    margin: 0 0 12px;
    font-size: clamp(1.7rem, 1.42rem + 1vw, 2.3rem);
  }

  .content :global(.case-hero p) {
    max-width: none;
    margin: 0;
    color: var(--muted);
  }

  .content :global(.case-hero dl) {
    display: grid;
    gap: 10px;
    margin: 0;
  }

  .content :global(.case-hero dl div) {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 14px 16px;
    background: color-mix(in srgb, var(--surface) 86%, transparent);
  }

  .content :global(.case-hero dt) {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .content :global(.case-hero dd) {
    margin: 5px 0 0;
    color: var(--text);
    font-weight: 800;
    line-height: 1.45;
  }

  .content :global(.capability-map),
  .content :global(.state-model) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .content :global(.tradeoff-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .content :global(.capability-map article),
  .content :global(.state-model > div),
  .content :global(.tradeoff-grid article) {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px;
    background: var(--surface-soft);
    box-shadow: var(--shadow-soft);
  }

  .content :global(.capability-map strong) {
    display: block;
    margin-bottom: 8px;
    color: var(--text);
    font-size: 1rem;
  }

  .content :global(.capability-map span) {
    display: block;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .content :global(.architecture-diagram) {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .content :global(.architecture-diagram section) {
    position: relative;
    display: grid;
    align-content: start;
    gap: 9px;
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 16px;
    background: var(--surface-soft);
    box-shadow: var(--shadow-soft);
  }

  .content :global(.architecture-diagram section:not(:last-child)::after) {
    position: absolute;
    top: 50%;
    right: -15px;
    z-index: 1;
    width: 18px;
    height: 2px;
    background: var(--accent);
    content: "";
  }

  .content :global(.architecture-diagram h3),
  .content :global(.state-model h3),
  .content :global(.tradeoff-grid h3) {
    max-width: none;
    margin: 0;
    color: var(--text);
    font-size: 1rem;
    line-height: 1.35;
  }

  .content :global(.diagram-node) {
    min-height: 42px;
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 9px 10px;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    color: var(--content-text);
    font-size: 0.85rem;
    font-weight: 750;
    line-height: 1.35;
  }

  .content :global(.diagram-node.primary) {
    border-color: color-mix(in srgb, var(--accent) 55%, var(--line));
    color: var(--accent-strong);
  }

  .content :global(.diagram-node.accent) {
    background: color-mix(in srgb, var(--accent) 12%, var(--surface-soft));
    color: var(--accent-strong);
  }

  .content :global(.diagram-note) {
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 650;
    line-height: 1.55;
  }

  .content :global(.sequence-diagram) {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px;
    background: var(--surface-soft);
    box-shadow: var(--shadow-soft);
  }

  .content :global(.sequence-participants) {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 8px;
    margin-bottom: 16px;
  }

  .content :global(.sequence-participants span) {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 7px 10px;
    background: var(--surface);
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 850;
    text-align: center;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .content :global(.sequence-diagram ol) {
    display: grid;
    gap: 10px;
    max-width: none;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .content :global(.sequence-diagram li) {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 12px;
    align-items: start;
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 14px;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
  }

  .content :global(.sequence-index) {
    display: inline-grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 14%, var(--surface-soft));
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .content :global(.sequence-diagram strong) {
    display: block;
    color: var(--text);
    font-size: 1rem;
  }

  .content :global(.sequence-diagram p),
  .content :global(.state-model p),
  .content :global(.tradeoff-grid p) {
    max-width: none;
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .content :global(.pipeline-diagram) {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 10px;
  }

  .content :global(.pipeline-diagram span) {
    position: relative;
    display: grid;
    min-height: 64px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 10px;
    background: var(--surface-soft);
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 850;
    text-align: center;
    box-shadow: var(--shadow-soft);
  }

  .content :global(.pipeline-diagram span:not(:last-child)::after) {
    position: absolute;
    top: 50%;
    right: -11px;
    z-index: 1;
    width: 12px;
    height: 2px;
    background: var(--accent);
    content: "";
  }

  @keyframes flow-line {
    0% {
      transform: translateX(0) scaleX(0.4);
    }

    40% {
      transform: translateX(48vw) scaleX(1);
    }

    100% {
      transform: translateX(1100px) scaleX(0.35);
    }
  }

  .content :global(.image-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    max-width: 980px;
    margin: 2rem auto;
  }

  .content :global(figure) {
    margin: 0;
  }

  .content :global(figcaption) {
    margin-top: 8px;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.45;
    text-align: center;
