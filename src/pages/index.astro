---
import { ArrowRight, Mail } from '@lucide/astro';
import { getCollection } from 'astro:content';
import GitHubIcon from '../components/GitHubIcon.astro';
import PostCard from '../components/PostCard.astro';
import ProfileCard from '../components/ProfileCard.astro';
import Layout from '../layouts/Layout.astro';
import { getFeaturedBlogEntries } from '../lib/posts';
import { portfolioProjects } from '../lib/projects';

const featuredEntries = getFeaturedBlogEntries(await getCollection('blog'), 3);

const currentProject = portfolioProjects[0];
---

<Layout
  title="Kirin Works"
  description="Kirin's portfolio, GitHub projects, and project notes."
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow"><strong>Portfolio</strong> / Kirin Works</p>
        <h1 data-i18n-zh="全栈工程作品集。" data-i18n-en="Full-stack engineering portfolio.">全栈工程作品集。</h1>
        <p class="intro">
          <span
            data-i18n-zh="医学影像、实时信号处理和本地知识工具方向的项目实践。"
            data-i18n-en="Project work across medical imaging, real-time signal processing, and local knowledge tools."
          >
            医学影像、实时信号处理和本地知识工具方向的项目实践。
          </span>
        </p>
        <div class="button-row">
          <a class="button primary" href="/projects/">
            <span data-i18n-zh="查看项目" data-i18n-en="View projects">查看项目</span>
            <ArrowRight size={18} stroke-width={2.2} />
          </a>
          <a class="button" href="https://github.com/l5769389">
            <GitHubIcon size={18} />
            <span data-i18n-zh="GitHub 主页" data-i18n-en="GitHub">GitHub 主页</span>
          </a>
          <a class="button quiet" href="mailto:5769389@qq.com">
            <Mail size={18} stroke-width={2.2} />
            <span data-i18n-zh="联系我" data-i18n-en="Contact">联系我</span>
          </a>
        </div>
      </div>

      <aside class="hero-project" aria-label="Current featured project">
        <div class="hero-project-body">
          <h2>{currentProject.name}</h2>
          <p data-i18n-zh={currentProject.descriptionZh} data-i18n-en={currentProject.descriptionEn}>
            {currentProject.descriptionZh}
          </p>
          <a class="hero-image" href={currentProject.href} aria-label={`Open ${currentProject.name}`}>
            <img src={currentProject.image} alt={`${currentProject.name} project screenshot`} />
          </a>
          <div class="tech-list compact-tags">
            <span class="tag" data-i18n-zh="当前展示" data-i18n-en="Featured">当前展示</span>
            <span class="tag area-tag">{currentProject.area}</span>
            {currentProject.tags.map((item) => <span class="tag">{item}</span>)}
          </div>
          <div class="card-links">
            <a href={currentProject.href}>
              <span data-i18n-zh="项目介绍" data-i18n-en="Project intro">项目介绍</span>
              <ArrowRight size={17} stroke-width={2.2} />
            </a>
            {
              currentProject.reviewHref && (
                <a href={currentProject.reviewHref}>
                  <span data-i18n-zh="复盘记录" data-i18n-en="Review notes">复盘记录</span>
                  <ArrowRight size={17} stroke-width={2.2} />
                </a>
              )
            }
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="work-section">
    <div class="container">
      <div class="section-heading">
        <h2 data-i18n-zh="代表项目" data-i18n-en="Selected Work">代表项目</h2>
        <a class="section-link" href="/projects/">
          <span data-i18n-zh="查看全部" data-i18n-en="View all">查看全部</span>
          <ArrowRight size={17} stroke-width={2.2} />
        </a>
      </div>
      <div class="work-grid">
        {
          portfolioProjects.map((project) => (
            <article class="work-card">
              <div class="work-body">
                <h3>{project.name}</h3>
                <p data-i18n-zh={project.descriptionZh} data-i18n-en={project.descriptionEn}>
                  {project.descriptionZh}
                </p>
                <a class="work-image" href={project.href} aria-label={`Open ${project.name}`}>
                  <img src={project.image} alt={`${project.name} project screenshot`} />
                </a>
                <div class="tech-list">
                  <span class="tag area-tag">{project.area}</span>
                  {project.tags.map((item) => <span class="tag">{item}</span>)}
                </div>
                <div class="card-links">
                  <a href={project.href}>
                    <span data-i18n-zh="项目介绍" data-i18n-en="Project intro">项目介绍</span>
                    <ArrowRight size={17} stroke-width={2.2} />
                  </a>
                  {
                    project.reviewHref && (
                      <a href={project.reviewHref}>
                        <span data-i18n-zh="复盘记录" data-i18n-en="Review notes">复盘记录</span>
                        <ArrowRight size={17} stroke-width={2.2} />
                      </a>
                    )
                  }
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="home-content">
    <div class="container content-grid">
      <div class="featured">
        <div class="section-heading">
          <h2 data-i18n-zh="项目复盘" data-i18n-en="Project Notes">项目复盘</h2>
          <a class="section-link" href="/blog/">
            <span data-i18n-zh="全部文章" data-i18n-en="All posts">全部文章</span>
            <ArrowRight size={17} stroke-width={2.2} />
          </a>
        </div>
        <div class="notes-list">
          {featuredEntries.map((entry) => <PostCard entry={entry} compact />)}
        </div>
      </div>
      <ProfileCard />
    </div>
  </section>
</Layout>

<style>
  .hero {
    border-bottom: 1px solid var(--line);
    background: var(--hero-bg);
  }

  .hero-grid {
    display: grid;
    min-height: 610px;
    align-items: center;
    grid-template-columns: minmax(320px, 0.9fr) minmax(520px, 1.1fr);
    gap: 54px;
    padding: 58px 0;
  }

  .hero-copy {
    min-width: 0;
    max-width: 680px;
  }

  h1 {
    margin: 0;
    max-width: 720px;
    font-size: clamp(2.8rem, 1.7rem + 3.7vw, 5.2rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .intro {
    max-width: 640px;
    margin: 26px 0 0;
    color: var(--muted);
    font-size: 1.12rem;
    line-height: 1.8;
  }

  .button.quiet {
    color: var(--link-muted);
  }

  .hero-project,
  .work-card {
    min-width: 0;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-soft) 46%, transparent), transparent 42%),
      var(--surface);
    box-shadow:
      0 18px 42px rgba(0, 0, 0, 0.22),
      inset 0 1px 0 color-mix(in srgb, white 10%, transparent);
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .hero-project:hover,
  .work-card:hover {
    border-color: color-mix(in srgb, var(--accent) 52%, var(--line-strong));
    box-shadow:
      0 24px 54px rgba(0, 0, 0, 0.3),
      0 0 0 1px color-mix(in srgb, var(--accent) 22%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 14%, transparent);
    transform: translateY(-2px);
  }

  .hero-project {
    overflow: hidden;
  }

  .hero-image,
  .work-image {
    display: block;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #080d13;
  }

  .hero-image img,
  .work-image img {
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .hero-image {
    margin-top: 22px;
    border-color: var(--line-strong);
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.2);
  }

  .hero-project-body {
    display: flex;
    min-height: 0;
    flex-direction: column;
    padding: 26px;
  }

  .project-label {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 12px;
    margin-bottom: 10px;
  }

  .project-label span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 10px;
    color: var(--tag-text);
    font-size: 0.82rem;
    font-weight: 750;
  }

  .project-label strong {
    display: inline-flex;
    margin-bottom: 8px;
    color: var(--accent-strong);
    font-size: 0.84rem;
    font-weight: 850;
  }

  .hero-project h2,
  .work-card h3 {
    margin: 0 0 8px;
    font-size: 1.45rem;
    line-height: 1.2;
  }

  .work-card h3 {
    min-height: 0;
  }

  .hero-project p,
  .work-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.72;
  }

  .work-card p {
    display: -webkit-box;
    min-height: 84px;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .card-links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 16px;
  }

  .work-card .card-links {
    margin-top: auto;
    padding-top: 18px;
  }

  .card-links a {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 0 2px;
    color: var(--accent-strong);
    font-weight: 800;
    line-height: 1;
  }

  .card-links a span {
    margin: 0;
    color: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: 1;
  }

  .card-links a svg {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
  }

  .work-section {
    padding: 36px 0;
    border-bottom: 1px solid var(--line);
    background: var(--home-bg);
  }

  .work-grid {
    display: grid;
    align-items: stretch;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .work-card {
    display: grid;
    overflow: hidden;
  }

  .work-image {
    margin-top: 22px;
    border-color: var(--line-strong);
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.2);
  }

  .work-body {
    display: flex;
    min-height: 520px;
    flex-direction: column;
    padding: 26px;
  }

  .tech-list {
    display: flex;
    height: 92px;
    align-content: flex-start;
    flex-wrap: wrap;
    gap: 10px 8px;
    margin-top: 22px;
    overflow: hidden;
  }

  .work-card .tag {
    min-height: 34px;
    line-height: 1.15;
  }

  .work-card .area-tag {
    border-color: color-mix(in srgb, var(--accent) 42%, var(--line));
    color: var(--accent-strong);
  }

  .hero-project .area-tag {
    border-color: color-mix(in srgb, var(--accent) 42%, var(--line));
    color: var(--accent-strong);
  }

  .compact-tags {
    height: auto;
    margin-top: 18px;
  }

  .home-content {
    padding: 36px 0 52px;
    background: var(--home-bg);
  }

  .content-grid {
    display: grid;
    align-items: start;
    grid-template-columns: minmax(0, 1fr) 350px;
    gap: 44px;
  }

  .featured {
    min-width: 0;
  }

  .notes-list {
    display: grid;
    gap: 18px;
  }

  @media (max-width: 1180px) {
    .hero-grid,
    .content-grid {
      grid-template-columns: 1fr;
    }

    .hero-grid {
      gap: 28px;
      padding-top: 42px;
    }

    .hero-copy {
      max-width: 760px;
    }

    .work-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .work-grid,
    .notes-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero-grid {
      min-height: auto;
    }

    h1 {
      width: 100%;
      max-width: 100%;
      font-size: 1.82rem;
      overflow-wrap: anywhere;
      word-break: break-all;
    }

    .intro {
      width: 100%;
      max-width: 100%;
      font-size: 1rem;
      overflow-wrap: anywhere;
    }

    .button-row {
      max-width: calc(100vw - 28px);
    }

    .hero-project-body,
    .work-body {
      padding: 22px;
    }

    .work-body,
    .work-card h3,
    .work-card p,
    .tech-list {
      min-height: 0;
      height: auto;
    }
  }
</style>
