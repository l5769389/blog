---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import Layout from '../layouts/Layout.astro';
import { getBlogEntries } from '../lib/posts';

const entries = getBlogEntries(await getCollection('blog'));
---

<Layout
  title="Blog"
  description="Project notes and engineering articles from Kirin."
>
  <section class="page-shell">
    <div class="container">
      <div class="page-header">
        <p class="eyebrow"><strong>Notes</strong></p>
        <h1 data-i18n-zh="项目笔记。" data-i18n-en="Project notes.">项目笔记。</h1>
        <p>
          <span
            data-i18n-zh="项目复盘、架构选择、实现细节和截图说明。"
            data-i18n-en="Project reviews, architecture choices, implementation details, and screenshots."
          >
            项目复盘、架构选择、实现细节和截图说明。
          </span>
        </p>
      </div>

      <div class="post-list">
        {entries.map((entry) => <PostCard entry={entry} compact />)}
      </div>
    </div>
  </section>
</Layout>

<style>
  .post-list {
    display: grid;
    gap: 22px;
  }
</style>
