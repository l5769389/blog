---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import Layout from '../layouts/Layout.astro';
import { sortPosts } from '../lib/posts';

const posts = sortPosts(await getCollection('blog'));
---

<Layout
  title="Blog"
  description="Project notes, build logs, and later long-form writing from Kirin."
>
  <section class="page-shell">
    <div class="container">
      <div class="page-header">
        <p class="eyebrow"><strong>Notes</strong></p>
        <h1>项目笔记和后续博客。</h1>
        <p>
          现在这里会优先记录作品集项目、截图说明和技术取舍；之后也会继续补充更常规的 blog 写作。
        </p>
      </div>

      <div class="post-list">
        {posts.map((post) => <PostCard post={post} compact />)}
      </div>
    </div>
  </section>
</Layout>

<style>
  .post-list {
    display: grid;
    gap: 22px;
  }
</style>
