---
import { ArrowRight } from '@lucide/astro';
import GitHubIcon from '../components/GitHubIcon.astro';
import Layout from '../layouts/Layout.astro';
import { portfolioProjects } from '../lib/projects';
---

<Layout title="Projects" description="Selected portfolio projects from Kirin.">
  <section class="page-shell">
    <div class="container">
      <div class="page-header compact-header">
        <p class="eyebrow"><strong>Projects</strong></p>
        <h1 data-i18n-zh="代表作品集项目。" data-i18n-en="Selected portfolio projects.">代表作品集项目。</h1>
      </div>

      <div class="projects-grid">
        {
          portfolioProjects.map(({ name, descriptionZh, descriptionEn, tech, statusZh, statusEn, href, reviewHref, githubHref, image }) => (
            <article class="project-card">
              <div class="project-body">
                <h2>{name}</h2>
                <p class="project-description" data-i18n-zh={descriptionZh} data-i18n-en={descriptionEn}>
                  {descriptionZh}
                </p>
                <a class="project-image" href={href} aria-label={`Open ${name} project intro`}>
                  <img src={image} alt={`${name} project screenshot`} />
                </a>
                <div class="tech-list">
                  <span class="tag status-tag" data-i18n-zh={statusZh} data-i18n-en={statusEn}>{statusZh}</span>
                  {tech.map((item) => (
                    <span class="tag">{item}</span>
                  ))}
                </div>
                <div class="project-links">
                  <a href={href} aria-label={`Read ${name} project intro`}>
                    <span data-i18n-zh="项目介绍" data-i18n-en="Project intro">项目介绍</span>
                    <ArrowRight size={17} stroke-width={2.2} />
                  </a>
                  {
                    reviewHref && (
                      <a href={reviewHref} aria-label={`Read ${name} review notes`}>
                        <span data-i18n-zh="复盘记录" data-i18n-en="Review notes">复盘记录</span>
                        <ArrowRight size={17} stroke-width={2.2} />
                      </a>
                    )
                  }
                  <a href={githubHref} aria-label={`Open ${name} on GitHub`}>
                    <span data-i18n-zh="GitHub 源码" data-i18n-en="Source">GitHub 源码</span>
                    <GitHubIcon size={17} />
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .compact-header {
    margin-bottom: 42px;
  }

  .projects-grid {
    display: grid;
    align-items: stretch;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .project-card {
    display: grid;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-soft) 46%, transparent), transparent 42%),
      var(--surface);
    box-shadow:
      0 18px 42px rgba(0, 0, 0, 0.22),
      inset 0 1px 0 color-mix(in srgb, white 10%, transparent);
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .project-card:hover {
    border-color: color-mix(in srgb, var(--accent) 52%, var(--line-strong));
    box-shadow:
      0 24px 54px rgba(0, 0, 0, 0.3),
      0 0 0 1px color-mix(in srgb, var(--accent) 22%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 14%, transparent);
    transform: translateY(-2px);
  }

  .project-image {
    display: block;
    overflow: hidden;
    margin-top: 22px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: #080d13;
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.2);
  }

  .project-image img {
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .project-body {
    display: flex;
    min-height: 560px;
    flex-direction: column;
    padding: 26px;
  }

  h2 {
    margin: 0 0 12px;
    font-size: 1.55rem;
    line-height: 1.25;
  }

  .project-description {
    display: -webkit-box;
    min-height: 86px;
    margin: 0;
    overflow: hidden;
    color: var(--muted);
    line-height: 1.72;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .tech-list {
    display: flex;
    height: 92px;
    align-content: flex-start;
    flex-wrap: wrap;
    gap: 10px 8px;
    margin-top: 24px;
    overflow: hidden;
  }

  .project-card .tag {
    min-height: 34px;
    line-height: 1.15;
  }

  .project-card .status-tag {
    border-color: color-mix(in srgb, var(--accent) 42%, var(--line));
    color: var(--accent-strong);
  }

  .project-links {
    display: flex;
    min-height: 34px;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: auto;
    padding-top: 18px;
  }

  .project-links a {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    gap: 8px;
    border-radius: 999px;
    padding: 0 2px;
    color: var(--accent-strong);
    font-weight: 800;
    line-height: 1;
  }

  .project-links a span {
    line-height: 1;
  }

  .project-links a svg {
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
  }

  @media (max-width: 1120px) {
    .projects-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 740px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .project-body {
      min-height: 0;
      padding: 22px;
    }

    h2,
    .project-description,
    .tech-list {
      min-height: 0;
      height: auto;
    }
  }
</style>
