---
import { ArrowUpRight, BookOpenText, Layers, Sparkles } from '@lucide/astro';
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    name: 'Kirin Blog',
    description: 'A fast personal blog built with Astro, Markdown content collections, and a calm visual system.',
    tech: ['Astro', 'TypeScript', 'CSS'],
    status: 'Active',
    Icon: BookOpenText,
  },
  {
    name: 'Component Notes',
    description: 'A living notebook for small UI patterns, accessibility decisions, and reusable frontend recipes.',
    tech: ['Design Systems', 'Docs'],
    status: 'Drafting',
    Icon: Layers,
  },
  {
    name: 'Idea Forge',
    description: 'A lightweight project log for shaping rough ideas into buildable product experiments.',
    tech: ['Product', 'Writing'],
    status: 'Exploring',
    Icon: Sparkles,
  },
];
---

<Layout title="Projects" description="Selected projects and experiments from Kirin.">
  <section class="page-shell">
    <div class="container">
      <div class="page-header">
        <p class="eyebrow"><strong>Projects</strong></p>
        <h1>Small bets, useful tools, and written experiments.</h1>
        <p>
          A concise index of things I am building, improving, or using as a
          place to think through product and engineering ideas.
        </p>
      </div>

      <div class="projects-grid">
        {
          projects.map(({ name, description, tech, status, Icon }) => (
            <article class="project-card">
              <div class="project-top">
                <Icon size={28} stroke-width={2.1} />
                <span>{status}</span>
              </div>
              <h2>{name}</h2>
              <p>{description}</p>
              <div class="tech-list">
                {tech.map((item) => (
                  <span class="tag">{item}</span>
                ))}
              </div>
              <a href="#" aria-label={`Open ${name}`}>
                Open project <ArrowUpRight size={17} stroke-width={2.2} />
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .project-card {
    display: flex;
    min-height: 360px;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 26px;
    background: var(--surface);
    box-shadow: 0 14px 36px rgba(25, 31, 48, 0.05);
  }

  .project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 34px;
  }

  .project-top svg {
    color: var(--accent-strong);
  }

  .project-top span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 10px;
    color: #4f5767;
    font-size: 0.82rem;
    font-weight: 750;
  }

  h2 {
    margin: 0 0 12px;
    font-size: 1.35rem;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
  }

  .project-card a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: auto;
    padding-top: 28px;
    color: var(--accent-strong);
    font-weight: 800;
  }

  @media (max-width: 980px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .project-card {
      min-height: auto;
    }
  }
</style>
