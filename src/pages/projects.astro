---
import { Activity, ArrowRight, ArrowUpRight, Layers } from '@lucide/astro';
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    name: 'RespiraScope',
    description:
      '呼吸信号采集、实时滤波、峰谷识别、BPM 计算、记录复盘和 Web Console 展示工具。',
    tech: ['FastAPI', 'Socket.IO', 'Signal Processing', 'PyInstaller'],
    status: 'Featured',
    noteHref: '/blog/respira-scope-realtime-breath-workbench',
    githubHref: 'https://github.com/l5769389/RespiraScope',
    image: '/images/respira-scope/breath-monitor.png',
    Icon: Activity,
  },
  {
    name: 'DicomVision',
    description:
      '面向 DICOM 阅片、MPR 重建、测量分析、DICOM 标签检查和 QA 流程的医学影像工作台。',
    tech: ['Vue 3', 'FastAPI', 'Electron', 'DICOM'],
    status: 'Featured',
    noteHref: '/blog/dicom-vision-imaging-workbench',
    githubHref: 'https://github.com/l5769389/DicomVisionClient',
    image: '/images/dicom-vision/theme-dark.png',
    Icon: Layers,
  },
];
---

<Layout title="Projects" description="Selected portfolio projects from Kirin.">
  <section class="page-shell">
    <div class="container">
      <div class="page-header">
        <p class="eyebrow"><strong>Projects</strong></p>
        <h1>两个重点作品集项目。</h1>
        <p>
          这里不再把 GitHub 主页当成一个项目，而是直接展示 RespiraScope 和 DicomVision。每个项目都提供源码入口和对应的项目复盘，方便快速判断项目形态与实现深度。
        </p>
      </div>

      <div class="projects-grid">
        {
          projects.map(({ name, description, tech, status, noteHref, githubHref, image, Icon }) => (
            <article class="project-card">
              <a class="project-image" href={noteHref} aria-label={`Open ${name} case note`}>
                <img src={image} alt={`${name} project screenshot`} />
              </a>
              <div class="project-body">
                <div class="project-top">
                  <Icon size={28} stroke-width={2.1} />
                  <span>{status}</span>
                </div>
                <h2>{name}</h2>
                <p>{description}</p>
                <div class="tech-list">
                  {tech.map((item) => (
                    <span class="tag">{item}</span>
                  ))}
                </div>
                <div class="project-links">
                  <a href={noteHref} aria-label={`Read ${name} case note`}>
                    项目复盘 <ArrowRight size={17} stroke-width={2.2} />
                  </a>
                  <a href={githubHref} aria-label={`Open ${name} on GitHub`}>
                    GitHub 源码 <ArrowUpRight size={17} stroke-width={2.2} />
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
  }

  .project-card {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow-soft);
  }

  .project-image {
    display: block;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background: #080d13;
  }

  .project-image img {
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .project-body {
    padding: 26px;
  }

  .project-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 28px;
  }

  .project-top svg {
    color: var(--accent-strong);
  }

  .project-top span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 10px;
    color: var(--tag-text);
    font-size: 0.82rem;
    font-weight: 750;
  }

  h2 {
    margin: 0 0 12px;
    font-size: 1.55rem;
  }

  p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 28px;
  }

  .project-links a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--accent-strong);
    font-weight: 800;
  }

  @media (max-width: 980px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .project-body {
      padding: 22px;
    }
  }
</style>
