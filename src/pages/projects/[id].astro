---
import { ArrowLeft, ArrowRight } from '@lucide/astro';
import GitHubIcon from '../../components/GitHubIcon.astro';
import Layout from '../../layouts/Layout.astro';
import { portfolioProjects } from '../../lib/projects';

export function getStaticPaths() {
  return portfolioProjects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.name} Project`} description={project.introEn}>
  <section class="page-shell project-detail-shell">
    <div class="container project-container">
      <a class="back-link" href="/projects/">
        <ArrowLeft size={17} stroke-width={2.2} />
        <span data-i18n-zh="返回项目" data-i18n-en="Back to projects">返回项目</span>
      </a>

      <header class="project-hero">
        <div class="project-copy">
          <p class="eyebrow"><strong>Project</strong> / {project.area}</p>
          <h1>{project.name}</h1>
          <p data-i18n-zh={project.introZh} data-i18n-en={project.introEn}>{project.introZh}</p>
          <div class="action-row">
            {
              project.reviewHref && (
                <a class="button primary" href={project.reviewHref}>
                  <span data-i18n-zh="复盘记录" data-i18n-en="Review notes">复盘记录</span>
                  <ArrowRight size={18} stroke-width={2.2} />
                </a>
              )
            }
            <a class="button" href={project.githubHref}>
              <GitHubIcon size={18} />
              <span data-i18n-zh="GitHub 源码" data-i18n-en="Source">GitHub 源码</span>
            </a>
          </div>
        </div>
        <img class="project-screenshot" src={project.image} alt={`${project.name} project screenshot`} />
      </header>

      <section class="project-section">
        <div class="section-heading">
          <h2 data-i18n-zh="这个项目能做什么" data-i18n-en="What it does">这个项目能做什么</h2>
        </div>
        <div class="capability-grid">
          {
            project.capabilitiesZh.map((capability, index) => (
              <article>
                <span>{String(index + 1).padStart(2, '0')}</span>
                <p data-i18n-zh={capability} data-i18n-en={project.capabilitiesEn[index]}>
                  {capability}
                </p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="project-section">
        <div class="section-heading">
          <h2 data-i18n-zh="项目标签" data-i18n-en="Project tags">项目标签</h2>
        </div>
        <div class="tag-list">
          {project.highlightsZh.map((item, index) => (
            <span class="tag" data-i18n-zh={item} data-i18n-en={project.highlightsEn[index]}>{item}</span>
          ))}
          {project.tech.map((item) => <span class="tag">{item}</span>)}
        </div>
      </section>
    </div>
  </section>
</Layout>

<style>
  .project-detail-shell {
    background: var(--article-bg);
  }

  .project-container {
    width: min(100% - 40px, 1120px);
  }

  .back-link {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0 14px;
    background: var(--surface-soft);
    color: var(--muted);
    font-weight: 750;
    box-shadow: var(--button-shadow);
  }

  .back-link:hover {
    border-color: var(--line-strong);
    color: var(--accent-strong);
  }

  .project-hero {
    display: grid;
    align-items: center;
    grid-template-columns: minmax(0, 0.95fr) minmax(420px, 1.05fr);
    gap: 34px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    padding: 30px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface-soft) 48%, transparent), transparent 50%),
      var(--surface);
    box-shadow: var(--shadow-soft);
  }

  .project-copy {
    min-width: 0;
  }

  h1 {
    margin: 0 0 18px;
    font-size: clamp(2.2rem, 1.55rem + 2.2vw, 3.7rem);
    line-height: 1.08;
    letter-spacing: 0;
  }

  .project-copy p:not(.eyebrow) {
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .project-screenshot {
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: #080d13;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.24);
  }

  .action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .project-section {
    margin-top: 32px;
  }

  .capability-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .capability-grid article {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 18px;
    background: var(--surface);
    box-shadow: var(--shadow-soft);
  }

  .capability-grid span {
    display: inline-grid;
    width: 38px;
    height: 38px;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--accent) 42%, var(--line));
    border-radius: 999px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 900;
  }

  .capability-grid p {
    margin: 0;
    color: var(--muted);
    line-height: 1.68;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  @media (max-width: 900px) {
    .project-hero,
    .capability-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .project-container {
      width: min(100% - 28px, 1120px);
    }

    .project-hero {
      padding: 22px;
    }

    .action-row .button {
      width: 100%;
    }
  }
</style>
