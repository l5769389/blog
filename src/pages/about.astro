---
import { BriefcaseBusiness, Camera, CodeXml, Compass, Mail, Video } from '@lucide/astro';
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import GitHubIcon from '../components/GitHubIcon.astro';
import { getLifeMoments } from '../lib/lifeMoments';

const values = [
  {
    titleZh: '全栈开发',
    titleEn: 'Full-stack development',
    bodyZh: '熟悉前端工程、后端服务、实时通信、桌面打包和项目交付。',
    bodyEn: 'Frontend engineering, backend services, real-time communication, desktop packaging, and product delivery.',
    Icon: CodeXml,
  },
  {
    titleZh: '医学与信号工具',
    titleEn: 'Medical and signal tools',
    bodyZh: '实践方向包括 DICOM 影像工作台、呼吸信号处理和数据可视化。',
    bodyEn: 'Work across DICOM imaging workbenches, respiration signal processing, and data visualization.',
    Icon: Compass,
  },
  {
    titleZh: '工程表达',
    titleEn: 'Engineering communication',
    bodyZh: '重视清晰的功能边界、可验证的流程和可维护的实现。',
    bodyEn: 'Clear product boundaries, verifiable workflows, and maintainable implementations.',
    Icon: CodeXml,
  },
];

const lifeMoments = getLifeMoments();
---

<Layout title="Life" description="Life moments and the person behind Kirin Works.">
  <section class="page-shell">
    <div class="container about-grid">
      <div class="page-header">
        <p class="eyebrow">Life <strong>& Work</strong></p>
        <h1
          data-i18n-zh="写代码，也认真收藏生活里的光。"
          data-i18n-en="Building software while keeping the light from everyday life close."
        >
          写代码，也认真收藏生活里的光。
        </h1>
        <p>
          <span
            data-i18n-zh="这里放个人侧影、家庭影像和一些不属于项目文档的日常片段。技术作品仍然放在项目和博客里，生活本身也值得有一个安静的位置。"
            data-i18n-en="A quieter place for personal notes, family media, and moments outside project documents."
          >
            这里放个人侧影、家庭影像和一些不属于项目文档的日常片段。技术作品仍然放在项目和博客里，生活本身也值得有一个安静的位置。
          </span>
        </p>
        <SocialLinks />
      </div>

      <aside class="about-card">
        <figure class="family-photo">
          <img
            src="/media/life/2026-05-29-little-light.webp"
            srcset="/media/life/2026-05-29-little-light-560.webp 560w, /media/life/2026-05-29-little-light.webp 960w"
            sizes="(max-width: 960px) calc(100vw - 48px), 360px"
            width="960"
            height="721"
            alt="生活里的温暖瞬间"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <figcaption
            data-i18n-zh="生活里的小小光源，也提醒我把工具做得更可靠、更有人味。"
            data-i18n-en="A quiet light in everyday life, reminding me to build tools with care and steadiness."
          >
            生活里的小小光源，也提醒我把工具做得更可靠、更有人味。
          </figcaption>
        </figure>
        <h2>Kirin</h2>
        <p data-i18n-zh="上海，中国" data-i18n-en="Shanghai, China">上海，中国</p>
        <div class="role">
          <BriefcaseBusiness size={18} />
          <span data-i18n-zh="全栈工程师 / 中国科学技术大学" data-i18n-en="Full-Stack Engineer / USTC">全栈工程师 / 中国科学技术大学</span>
        </div>
        <div class="contact-actions">
          <a href="https://github.com/l5769389"><GitHubIcon size={17} /> GitHub</a>
          <a href="mailto:5769389@qq.com"><Mail size={17} /> Email</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="life-section">
    <div class="container">
      <div class="section-heading">
        <h2 data-i18n-zh="生活时间线" data-i18n-en="Life Timeline">生活时间线</h2>
      </div>
      <div class="life-timeline">
        {
          lifeMoments.map((moment) => {
            const MediaIcon = moment.media.type === 'video' ? Video : Camera;
            const mediaLabelZh = moment.media.type === 'video' ? '视频' : '照片';
            const mediaLabelEn = moment.media.type === 'video' ? 'Video' : 'Photo';

            return (
              <article class="life-moment">
                <div class="moment-media">
                  {
                    moment.media.type === 'video' ? (
                      <video
                        controls
                        preload="metadata"
                        poster={moment.media.poster}
                        aria-label={moment.media.altZh}
                      >
                        <source src={moment.media.src} />
                      </video>
                    ) : (
                      <img
                        src={moment.media.src}
                        srcset={moment.media.srcSet}
                        sizes={moment.media.sizes}
                        width={moment.media.width}
                        height={moment.media.height}
                        alt={moment.media.altZh}
                        loading="lazy"
                        decoding="async"
                      />
                    )
                  }
                </div>
                <div class="moment-body">
                  <div class="moment-meta">
                    <time
                      datetime={moment.date}
                      data-i18n-zh={moment.displayDateZh}
                      data-i18n-en={moment.displayDateEn}
                    >
                      {moment.displayDateZh}
                    </time>
                    <span class="moment-kind">
                      <MediaIcon size={16} stroke-width={2.2} />
                      <span data-i18n-zh={mediaLabelZh} data-i18n-en={mediaLabelEn}>{mediaLabelZh}</span>
                    </span>
                  </div>
                  <h3 data-i18n-zh={moment.titleZh} data-i18n-en={moment.titleEn}>{moment.titleZh}</h3>
                  <p data-i18n-zh={moment.descriptionZh} data-i18n-en={moment.descriptionEn}>
                    {moment.descriptionZh}
                  </p>
                </div>
              </article>
            );
          })
        }
      </div>
    </div>
  </section>

  <section class="about-section">
    <div class="container values-grid">
      {
        values.map(({ titleZh, titleEn, bodyZh, bodyEn, Icon }) => (
          <article class="value-card">
            <Icon size={24} stroke-width={2.2} />
            <h2 data-i18n-zh={titleZh} data-i18n-en={titleEn}>{titleZh}</h2>
            <p data-i18n-zh={bodyZh} data-i18n-en={bodyEn}>{bodyZh}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="page-shell timeline-shell">
    <div class="container timeline">
      <div class="section-heading">
        <h2 data-i18n-zh="项目方向" data-i18n-en="Focus Areas">项目方向</h2>
      </div>
      <div class="timeline-list">
        <article>
          <span>RespiraScope</span>
          <h3
            data-i18n-zh="实时呼吸信号处理"
            data-i18n-en="Real-time respiration signal processing"
          >
            实时呼吸信号处理
          </h3>
          <p
            data-i18n-zh="采集、滤波、峰谷识别、BPM 计算、记录复算和 Web Console 展示。"
            data-i18n-en="Acquisition, filtering, peak detection, BPM calculation, recording review, and Web Console visualization."
          >
            采集、滤波、峰谷识别、BPM 计算、记录复算和 Web Console 展示。
          </p>
        </article>
        <article>
          <span>DicomVision</span>
          <h3
            data-i18n-zh="DICOM 医学影像工作台"
            data-i18n-en="DICOM medical imaging workbench"
          >
            DICOM 医学影像工作台
          </h3>
          <p
            data-i18n-zh="阅片、MPR 重建、测量分析、DICOM 标签检查、MTF/FWHM 和 QA 流程。"
            data-i18n-en="Stack viewing, MPR reconstruction, measurement, DICOM tag review, MTF/FWHM, and QA workflows."
          >
            阅片、MPR 重建、测量分析、DICOM 标签检查、MTF/FWHM 和 QA 流程。
          </p>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-grid {
    display: grid;
    align-items: center;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 52px;
  }

  .about-card,
  .value-card,
  .timeline-list article {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow-soft);
  }

  .about-card {
    padding: 28px;
  }

  .family-photo {
    margin: 0;
  }

  .family-photo img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: #080d13;
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.24);
  }

  .family-photo figcaption {
    margin-top: 12px;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.65;
  }

  .about-card h2 {
    margin: 22px 0 4px;
    font-size: 1.45rem;
  }

  .about-card p {
    margin: 0 0 16px;
    color: var(--muted);
  }

  .role {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--link-muted);
    font-weight: 750;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .contact-actions a {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0 13px;
    color: var(--link-muted);
    font-weight: 750;
  }

  .life-section {
    padding: 6px 0 38px;
  }

  .life-timeline {
    display: grid;
    gap: 18px;
  }

  .life-moment {
    display: grid;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow-soft);
    grid-template-columns: minmax(260px, 420px) minmax(0, 1fr);
  }

  .moment-media {
    border-right: 1px solid var(--line);
    background: var(--surface-soft);
  }

  .moment-media img,
  .moment-media video {
    width: 100%;
    height: 100%;
    min-height: 260px;
    object-fit: cover;
  }

  .moment-media video {
    background: #05070a;
  }

  .moment-body {
    display: flex;
    min-width: 0;
    flex-direction: column;
    justify-content: center;
    padding: 28px;
  }

  .moment-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .moment-kind {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--accent-strong);
  }

  .life-moment h3 {
    margin: 14px 0 10px;
    font-size: clamp(1.35rem, 1.18rem + 0.5vw, 1.8rem);
    line-height: 1.2;
  }

  .life-moment p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .about-section {
    padding: 18px 0 34px;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .value-card {
    padding: 26px;
  }

  .value-card svg {
    color: var(--accent-strong);
  }

  .value-card h2,
  .timeline h2,
  .timeline-list h3 {
    margin: 16px 0 10px;
    font-size: 1.2rem;
  }

  .value-card p,
  .timeline-list p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .timeline-shell {
    padding-top: 22px;
  }

  .timeline-list {
    display: grid;
    gap: 18px;
  }

  .timeline-list article {
    padding: 24px;
  }

  .timeline-list span {
    color: var(--accent-strong);
    font-size: 0.9rem;
    font-weight: 850;
  }

  @media (max-width: 960px) {
    .about-grid,
    .values-grid,
    .life-moment {
      grid-template-columns: 1fr;
    }

    .moment-media {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }
  }
</style>
