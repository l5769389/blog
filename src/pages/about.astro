---
import { BriefcaseBusiness, CodeXml, Compass, Mail } from '@lucide/astro';
import Layout from '../layouts/Layout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import GitHubIcon from '../components/GitHubIcon.astro';

const values = [
  {
    titleZh: '全栈开发',
    titleEn: 'Full-stack development',
    bodyZh: '熟悉前端工程、后端服务、实时通信、桌面打包和项目交付。',
    bodyEn: 'Frontend engineering, backend services, real-time communication, desktop packaging, and product delivery.',
    Icon: CodeXml,
  },
  {
    titleZh: '医学与信号工具',
    titleEn: 'Medical and signal tools',
    bodyZh: '实践方向包括 DICOM 影像工作台、呼吸信号处理和数据可视化。',
    bodyEn: 'Work across DICOM imaging workbenches, respiration signal processing, and data visualization.',
    Icon: Compass,
  },
  {
    titleZh: '工程表达',
    titleEn: 'Engineering communication',
    bodyZh: '重视清晰的功能边界、可验证的流程和可维护的实现。',
    bodyEn: 'Clear product boundaries, verifiable workflows, and maintainable implementations.',
    Icon: CodeXml,
  },
];
---

<Layout title="About" description="About Kirin, the person behind Kirin Works.">
  <section class="page-shell">
    <div class="container about-grid">
      <div class="page-header">
        <p class="eyebrow">About <strong>Kirin</strong></p>
        <h1
          data-i18n-zh="全栈工程师，关注实用工具和项目复盘。"
          data-i18n-en="Full-stack engineer building practical tools and project notes."
        >
          全栈工程师，关注实用工具和项目复盘。
        </h1>
        <p>
          <span
            data-i18n-zh="中国科学技术大学毕业，现居上海。主要方向包括医学影像、实时信号处理和 Web 工具。"
            data-i18n-en="USTC graduate based in Shanghai, focused on medical imaging, real-time signal processing, and web tools."
          >
            中国科学技术大学毕业，现居上海。主要方向包括医学影像、实时信号处理和 Web 工具。
          </span>
        </p>
        <SocialLinks />
      </div>

      <aside class="about-card">
        <div class="portrait" aria-hidden="true"><span></span></div>
        <h2>Kirin</h2>
        <p data-i18n-zh="上海，中国" data-i18n-en="Shanghai, China">上海，中国</p>
        <div class="role">
          <BriefcaseBusiness size={18} />
          <span data-i18n-zh="全栈工程师 / 中国科学技术大学" data-i18n-en="Full-Stack Engineer / USTC">全栈工程师 / 中国科学技术大学</span>
        </div>
        <div class="contact-actions">
          <a href="https://github.com/l5769389"><GitHubIcon size={17} /> GitHub</a>
          <a href="mailto:5769389@qq.com"><Mail size={17} /> Email</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="about-section">
    <div class="container values-grid">
      {
        values.map(({ titleZh, titleEn, bodyZh, bodyEn, Icon }) => (
          <article class="value-card">
            <Icon size={24} stroke-width={2.2} />
            <h2 data-i18n-zh={titleZh} data-i18n-en={titleEn}>{titleZh}</h2>
            <p data-i18n-zh={bodyZh} data-i18n-en={bodyEn}>{bodyZh}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="page-shell timeline-shell">
    <div class="container timeline">
      <div class="section-heading">
        <h2 data-i18n-zh="项目方向" data-i18n-en="Focus Areas">项目方向</h2>
      </div>
      <div class="timeline-list">
        <article>
          <span>RespiraScope</span>
          <h3
            data-i18n-zh="实时呼吸信号处理"
            data-i18n-en="Real-time respiration signal processing"
          >
            实时呼吸信号处理
          </h3>
          <p
            data-i18n-zh="采集、滤波、峰谷识别、BPM 计算、记录复算和 Web Console 展示。"
            data-i18n-en="Acquisition, filtering, peak detection, BPM calculation, recording review, and Web Console visualization."
          >
            采集、滤波、峰谷识别、BPM 计算、记录复算和 Web Console 展示。
          </p>
        </article>
        <article>
          <span>DicomVision</span>
          <h3
            data-i18n-zh="DICOM 医学影像工作台"
            data-i18n-en="DICOM medical imaging workbench"
          >
            DICOM 医学影像工作台
          </h3>
          <p
            data-i18n-zh="阅片、MPR 重建、测量分析、DICOM 标签检查、MTF/FWHM 和 QA 流程。"
            data-i18n-en="Stack viewing, MPR reconstruction, measurement, DICOM tag review, MTF/FWHM, and QA workflows."
          >
            阅片、MPR 重建、测量分析、DICOM 标签检查、MTF/FWHM 和 QA 流程。
          </p>
        </article>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-grid {
    display: grid;
    align-items: center;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 52px;
  }

  .about-card,
  .value-card,
  .timeline-list article {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow-soft);
  }

  .about-card {
    padding: 28px;
  }

  .portrait {
    position: relative;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 1.05;
    border-radius: var(--radius);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.2) 0 50%, transparent 50%),
      linear-gradient(135deg, #dfe8f5, #f3d6ca);
  }

  .portrait::before,
  .portrait::after,
  .portrait span {
    position: absolute;
    content: "";
  }

  .portrait::before {
    right: 36%;
    bottom: 38%;
    width: 70px;
    height: 76px;
    border-radius: 50%;
    background: #202633;
  }

  .portrait::after {
    right: 25%;
    bottom: 6%;
    width: 170px;
    height: 122px;
    border-radius: 80px 80px 20px 20px;
    background: #1b2230;
    transform: rotate(10deg);
  }

  .portrait span {
    right: 28%;
    bottom: 34%;
    z-index: 1;
    width: 48px;
    height: 36px;
    border-radius: 50%;
    background: #d3a58f;
  }

  .about-card h2 {
    margin: 22px 0 4px;
    font-size: 1.45rem;
  }

  .about-card p {
    margin: 0 0 16px;
    color: var(--muted);
  }

  .role {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--link-muted);
    font-weight: 750;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .contact-actions a {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0 13px;
    color: var(--link-muted);
    font-weight: 750;
  }

  .about-section {
    padding: 18px 0 34px;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .value-card {
    padding: 26px;
  }

  .value-card svg {
    color: var(--accent-strong);
  }

  .value-card h2,
  .timeline h2,
  .timeline-list h3 {
    margin: 16px 0 10px;
    font-size: 1.2rem;
  }

  .value-card p,
  .timeline-list p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .timeline-shell {
    padding-top: 22px;
  }

  .timeline-list {
    display: grid;
    gap: 18px;
  }

  .timeline-list article {
    padding: 24px;
  }

  .timeline-list span {
    color: var(--accent-strong);
    font-size: 0.9rem;
    font-weight: 850;
  }

  @media (max-width: 960px) {
    .about-grid,
    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
