---
import { ArrowRight } from '@lucide/astro';
import type { BlogPost } from '../lib/posts';
import { formatDateEn, formatDateZh, formatReadTimeEn, formatReadTimeZh } from '../lib/posts';

interface Props {
  post: BlogPost;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const { title, description, pubDate, readTime, tags, cover } = post.data;
const primaryTag = tags[0] ?? 'Notes';
---

<article class:list={['post-card', { compact }]}>
  <a class={`cover ${cover}`} href={`/blog/${post.id}`} aria-label={title}>
    {
      cover === 'typescript' && (
        <span class="ts-mark" aria-hidden="true">
          TS
        </span>
      )
    }
    {
      cover === 'architecture' && (
        <span class="wave-lines" aria-hidden="true">
          <i></i>
          <i></i>
          <i></i>
        </span>
      )
    }
    {
      cover === 'growth' && (
        <span class="seedling" aria-hidden="true">
          <i></i>
          <i></i>
          <b></b>
        </span>
      )
    }
    {
      cover === 'astro' && (
        <span class="astro-mark" aria-hidden="true">
          A
        </span>
      )
    }
    {
      cover === 'dicom' && (
        <span class="dicom-mark" aria-hidden="true">
          <i></i>
          <b>DV</b>
        </span>
      )
    }
    {
      cover === 'respira' && (
        <span class="respira-mark" aria-hidden="true">
          <i></i>
          <i></i>
          <i></i>
          <b>RS</b>
        </span>
      )
    }
    {
      cover === 'note' && (
        <span class="note-mark" aria-hidden="true">
          <i></i>
          <i></i>
          <i></i>
          <b>ND</b>
        </span>
      )
    }
  </a>

  <div class="post-body">
    <h3><a href={`/blog/${post.id}`}>{title}</a></h3>
    <p>{description}</p>
    <div class="post-meta">
      <span data-i18n-zh={formatDateZh(pubDate)} data-i18n-en={formatDateEn(pubDate)}>
        {formatDateZh(pubDate)}
      </span>
      <span>{primaryTag}</span>
      <span data-i18n-zh={formatReadTimeZh(readTime)} data-i18n-en={formatReadTimeEn(readTime)}>
        {formatReadTimeZh(readTime)}
      </span>
    </div>
    {
      compact && (
        <a class="read-link" href={`/blog/${post.id}`}>
          <span data-i18n-zh="阅读全文" data-i18n-en="Read post">阅读全文</span>
          <ArrowRight size={16} stroke-width={2.2} />
        </a>
      )
    }
  </div>
</article>

<style>
  .post-card {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--card-shadow);
  }

  .cover {
    position: relative;
    display: grid;
    min-height: 168px;
    place-items: center;
    overflow: hidden;
    border-bottom: 1px solid var(--cover-border);
  }

  .cover.typescript {
    background: var(--cover-typescript-bg);
  }

  .cover.architecture {
    background: var(--cover-architecture-bg);
  }

  .cover.growth {
    background: var(--cover-growth-bg);
  }

  .cover.astro {
    background: var(--cover-astro-bg);
  }

  .cover.dicom {
    background: var(--cover-dicom-bg);
  }

  .cover.respira {
    background: var(--cover-respira-bg);
  }

  .cover.note {
    background: var(--cover-note-bg);
  }

  .ts-mark,
  .astro-mark,
  .dicom-mark,
  .respira-mark,
  .note-mark {
    display: grid;
    width: 76px;
    height: 76px;
    place-items: center;
    border-radius: 8px;
    color: white;
    font-size: 2.3rem;
    font-weight: 900;
    box-shadow: 0 20px 42px rgba(64, 91, 211, 0.24);
  }

  .ts-mark {
    background: #5275df;
  }

  .astro-mark {
    background: linear-gradient(135deg, #2b2f7f, #c2566f);
  }

  .dicom-mark {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(180, 187, 255, 0.36);
    background:
      linear-gradient(90deg, transparent 48%, rgba(118, 211, 156, 0.34) 49% 51%, transparent 52%),
      linear-gradient(0deg, transparent 48%, rgba(240, 144, 170, 0.34) 49% 51%, transparent 52%),
      #101722;
    color: #eef3fb;
  }

  .dicom-mark i {
    position: absolute;
    inset: 14px;
    border: 1px solid rgba(137, 146, 255, 0.5);
    border-radius: 50%;
  }

  .dicom-mark b {
    position: relative;
    font-size: 1.5rem;
    letter-spacing: 0;
  }

  .respira-mark {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(118, 211, 156, 0.36);
    background: #0d1b17;
    color: #eefbf4;
  }

  .respira-mark i {
    position: absolute;
    left: -14px;
    width: 104px;
    height: 36px;
    border: 2px solid rgba(118, 211, 156, 0.48);
    border-right: 0;
    border-left: 0;
    border-radius: 50%;
  }

  .respira-mark i:nth-child(1) {
    top: 13px;
    transform: rotate(-13deg);
  }

  .respira-mark i:nth-child(2) {
    top: 25px;
    transform: rotate(9deg);
  }

  .respira-mark i:nth-child(3) {
    top: 38px;
    transform: rotate(-9deg);
  }

  .respira-mark b {
    position: relative;
    font-size: 1.5rem;
    letter-spacing: 0;
  }

  .note-mark {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(137, 146, 255, 0.34);
    background: #111827;
    color: #eef3fb;
  }

  .note-mark i {
    position: absolute;
    left: 14px;
    right: 14px;
    height: 2px;
    border-radius: 999px;
    background: rgba(180, 187, 255, 0.5);
  }

  .note-mark i:nth-child(1) {
    top: 21px;
  }

  .note-mark i:nth-child(2) {
    top: 32px;
    right: 28px;
  }

  .note-mark i:nth-child(3) {
    top: 43px;
  }

  .note-mark b {
    position: relative;
    align-self: end;
    margin-bottom: 14px;
    color: #eef3fb;
    font-size: 1.35rem;
    letter-spacing: 0;
  }

  .wave-lines {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .wave-lines i {
    position: absolute;
    left: -18%;
    width: 140%;
    height: 120px;
    border: 2px solid rgba(142, 165, 198, 0.34);
    border-radius: 50%;
    transform: rotate(-21deg);
  }

  .wave-lines i:nth-child(1) {
    top: 8px;
  }

  .wave-lines i:nth-child(2) {
    top: 42px;
  }

  .wave-lines i:nth-child(3) {
    top: 76px;
  }

  .seedling {
    position: relative;
    width: 86px;
    height: 94px;
  }

  .seedling b {
    position: absolute;
    bottom: 4px;
    left: 50%;
    width: 78px;
    height: 16px;
    border-radius: 50%;
    background: #51442f;
    transform: translateX(-50%);
  }

  .seedling i {
    position: absolute;
    bottom: 18px;
    left: 42px;
    width: 5px;
    height: 58px;
    border-radius: 999px;
    background: #4d7d42;
  }

  .seedling i:nth-child(1)::before,
  .seedling i:nth-child(2)::before {
    position: absolute;
    top: 0;
    width: 48px;
    height: 24px;
    border-radius: 100% 0 100% 0;
    background: linear-gradient(135deg, #7bb45d, #2f7d4c);
    content: "";
  }

  .seedling i:nth-child(1)::before {
    right: 2px;
    transform: rotate(18deg);
    transform-origin: right bottom;
  }

  .seedling i:nth-child(2)::before {
    left: 2px;
    transform: scaleX(-1) rotate(18deg);
    transform-origin: left bottom;
  }

  .post-body {
    padding: 21px 22px 24px;
  }

  .post-body h3 {
    margin: 0 0 10px;
    font-size: 1.06rem;
    line-height: 1.35;
  }

  .post-body p {
    min-height: 55px;
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    margin-top: 23px;
    color: var(--meta-text);
    font-size: 0.88rem;
  }

  .post-meta span + span::before {
    margin-right: 12px;
    color: var(--meta-divider);
    content: "/";
  }

  .read-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 20px;
    color: var(--accent-strong);
    font-weight: 750;
  }

  .post-card.compact {
    display: grid;
    grid-template-columns: minmax(190px, 32%) 1fr;
  }

  .post-card.compact .cover {
    min-height: 100%;
    border-right: 1px solid var(--cover-border);
    border-bottom: 0;
  }

  .post-card.compact .post-body p {
    min-height: auto;
  }

  @media (max-width: 700px) {
    .post-card.compact {
      grid-template-columns: 1fr;
    }

    .post-card.compact .cover {
      min-height: 160px;
      border-right: 0;
      border-bottom: 1px solid var(--cover-border);
    }
  }
</style>

