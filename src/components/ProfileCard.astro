---
import { Mail } from '@lucide/astro';
import GitHubIcon from './GitHubIcon.astro';

const chips = [
  { zh: '上海', en: 'Shanghai' },
  { zh: '全栈工程师', en: 'Full-Stack Engineer' },
  { zh: '中国科学技术大学', en: 'USTC' },
  { zh: '医学影像 / 信号处理', en: 'Medical Imaging / Signal Processing' },
  { zh: 'AI 协作 / 开源', en: 'AI Collaboration / Open Source' },
];
---

<aside class="profile-card" aria-label="About Kirin">
  <h2 class="card-title" data-i18n-zh="关于我" data-i18n-en="About Me">关于我</h2>
  <div class="profile-head">
    <div class="avatar" aria-hidden="true">
      <span></span>
    </div>
    <div>
      <h2>Kirin</h2>
      <p
        class="summary"
        data-i18n-zh="热爱 Vibe Coding，积极拥抱 AI 协作，以开源精神打磨可靠的工程工具。"
        data-i18n-en="Embracing AI-assisted vibe coding and open-source engineering to build reliable tools."
      >
        热爱 Vibe Coding，积极拥抱 AI 协作，以开源精神打磨可靠的工程工具。
      </p>
    </div>
  </div>

  <div class="chip-list" aria-label="Profile highlights">
    {
      chips.map((chip) => (
        <span data-i18n-zh={chip.zh} data-i18n-en={chip.en}>{chip.zh}</span>
      ))
    }
  </div>

  <div class="contact-grid">
    <a href="https://github.com/l5769389">
      <GitHubIcon size={18} />
      <span>GitHub</span>
    </a>
    <a href="mailto:5769389@qq.com">
      <Mail size={18} />
      <span>Email</span>
    </a>
  </div>
</aside>

<style>
  .profile-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .card-title {
    margin: 0 0 22px;
    color: var(--accent-strong);
    font-size: 1.35rem;
    line-height: 1.2;
  }

  .profile-head {
    display: grid;
    align-items: center;
    grid-template-columns: 112px 1fr;
    gap: 22px;
  }

  .avatar {
    position: relative;
    overflow: hidden;
    width: 112px;
    aspect-ratio: 1;
    border-radius: 50%;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.15) 0 48%, transparent 48%),
      linear-gradient(135deg, #ced8e7, #f2d8cf);
  }

  .avatar span,
  .avatar::before,
  .avatar::after {
    position: absolute;
    display: block;
    content: "";
  }

  .avatar::before {
    top: 30px;
    left: 40px;
    width: 34px;
    height: 38px;
    border-radius: 50%;
    background: #202633;
  }

  .avatar::after {
    right: 21px;
    bottom: 13px;
    width: 70px;
    height: 54px;
    border-radius: 35px 35px 14px 14px;
    background: #1b2230;
    transform: rotate(12deg);
  }

  .avatar span {
    right: 23px;
    bottom: 44px;
    z-index: 1;
    width: 27px;
    height: 22px;
    border-radius: 50%;
    background: #d3a58f;
  }

  h2 {
    margin: 0 0 7px;
    font-size: 1.85rem;
    line-height: 1.15;
  }

  .summary {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.65;
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin: 24px 0 20px;
  }

  .chip-list span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 7px 10px;
    background: var(--tag-bg);
    color: var(--tag-text);
    font-size: 0.84rem;
    font-weight: 700;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .contact-grid a {
    display: flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    color: var(--link-muted);
    font-weight: 750;
  }

  .contact-grid svg {
    color: var(--icon-color);
  }

  @media (max-width: 560px) {
    .profile-head {
      grid-template-columns: 1fr;
    }
  }
</style>
