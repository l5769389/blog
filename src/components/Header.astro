---
import { Moon, Sun } from '@lucide/astro';
import GitHubIcon from './GitHubIcon.astro';

const navItems = [
  { href: '/', labelZh: '首页', labelEn: 'Home' },
  { href: '/blog/', labelZh: '博客', labelEn: 'Blog' },
  { href: '/projects/', labelZh: '项目', labelEn: 'Projects' },
  { href: '/about/', labelZh: '生活', labelEn: 'Life' },
  { href: '/tags/', labelZh: '标签', labelEn: 'Tags' },
];

const normalizePath = (path: string) => path.replace(/\/$/, '') || '/';
const pathname = normalizePath(Astro.url.pathname);
const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);

  return normalizedHref === '/'
    ? pathname === '/'
    : pathname === normalizedHref || pathname.startsWith(`${normalizedHref}/`);
};
---

<header class="site-header">
  <div class="container nav-shell">
    <a class="brand" href="/" aria-label="Kirin Works home">
      <span class="brand-mark">K</span>
      <span>Kirin Works</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a
            class:list={['nav-link', { active: isActive(item.href) }]}
            href={item.href}
            data-i18n-zh={item.labelZh}
            data-i18n-en={item.labelEn}
          >
            {item.labelZh}
          </a>
        ))
      }
    </nav>

    <div class="nav-actions" aria-label="Header actions">
      <button type="button" data-theme-toggle aria-label="Switch to dark theme" title="Switch to dark theme">
        <span data-theme-icon-light aria-hidden="true">
          <Sun size={22} stroke-width={2.2} />
        </span>
        <span data-theme-icon-dark aria-hidden="true" hidden>
          <Moon size={22} stroke-width={2.2} />
        </span>
      </button>
      <button
        type="button"
        class="lang-button"
        data-lang-toggle
        aria-label="Switch language"
        title="Switch language"
        data-i18n-aria-label-zh="切换到英文"
        data-i18n-aria-label-en="Switch to Chinese"
        data-i18n-title-zh="切换到英文"
        data-i18n-title-en="Switch to Chinese"
      >
        <span class="lang-current" data-i18n-zh="EN" data-i18n-en="中">EN</span>
      </button>
      <a href="https://github.com/l5769389" aria-label="GitHub home" title="GitHub home">
        <GitHubIcon size={22} />
      </a>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const button = document.querySelector('[data-theme-toggle]');

    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    const getTheme = () =>
      document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
    const lightIcon = button.querySelector('[data-theme-icon-light]');
    const darkIcon = button.querySelector('[data-theme-icon-dark]');

    const updateButton = () => {
      const isDark = getTheme() === 'dark';
      const label = isDark ? 'Switch to light theme' : 'Switch to dark theme';

      button.setAttribute('aria-label', label);
      button.setAttribute('title', label);

      if (lightIcon instanceof HTMLElement) {
        lightIcon.hidden = isDark;
      }

      if (darkIcon instanceof HTMLElement) {
        darkIcon.hidden = !isDark;
      }
    };

    button.addEventListener('click', () => {
      const nextTheme = getTheme() === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = nextTheme;

      try {
        localStorage.setItem('theme', nextTheme);
      } catch {
        // Theme still changes for the current page even when storage is unavailable.
      }

      updateButton();
    });

    updateButton();
  })();
</script>

<style>
  .site-header {
    position: sticky;
    z-index: 10;
    top: 0;
    border-bottom: 1px solid var(--line);
    background: var(--header-bg);
    backdrop-filter: blur(18px);
  }

  .nav-shell {
    display: grid;
    min-height: 78px;
    align-items: center;
    grid-template-columns: 1fr auto 1fr;
    gap: 20px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    justify-self: start;
    font-size: 1.15rem;
    font-weight: 850;
  }

  .brand-mark {
    display: inline-grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: var(--brand-bg);
    box-shadow: var(--button-shadow);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: clamp(18px, 3vw, 42px);
    justify-self: center;
  }

  .nav-link {
    position: relative;
    padding: 28px 0 24px;
    color: var(--nav-text);
    font-size: 0.96rem;
    font-weight: 700;
  }

  .nav-link::after {
    position: absolute;
    right: 0;
    bottom: 10px;
    left: 0;
    height: 3px;
    border-radius: 999px;
    background: var(--accent);
    content: "";
    opacity: 0;
    transform: scaleX(0.5);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .nav-link.active::after,
  .nav-link:hover::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-self: end;
  }

  .nav-actions a,
  .nav-actions button {
    display: inline-grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 0;
    background: transparent;
    color: var(--icon-color);
    cursor: pointer;
  }

  .nav-actions .lang-button {
    display: inline-grid;
    width: 34px;
    min-width: 34px;
    height: 34px;
    border: 0;
    border-radius: 0;
    padding: 0;
    background: transparent;
    font-size: 0.84rem;
    font-weight: 850;
  }

  .lang-current {
    color: var(--icon-color);
    line-height: 1;
  }

  [data-theme-icon-light],
  [data-theme-icon-dark] {
    display: grid;
    place-items: center;
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 900px) {
    .nav-shell {
      grid-template-columns: 1fr auto;
      padding: 12px 0;
    }

    .nav-links {
      width: 100%;
      overflow-x: auto;
      grid-column: 1 / -1;
      grid-row: 2;
      justify-content: flex-start;
      padding-bottom: 4px;
      scrollbar-width: none;
    }

    .nav-links::-webkit-scrollbar {
      display: none;
    }

    .nav-link {
      padding: 8px 0 12px;
      white-space: nowrap;
    }

    .nav-link::after {
      bottom: 2px;
    }

    .nav-actions {
      gap: 8px;
    }
  }

  @media (max-width: 520px) {
    .brand {
      gap: 10px;
      font-size: 1rem;
    }

    .brand-mark {
      width: 36px;
      height: 36px;
    }

    .nav-actions {
      gap: 2px;
    }

    .nav-actions a {
      display: none;
    }
  }
</style>
