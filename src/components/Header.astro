---
import { CodeXml, Search, Sun } from '@lucide/astro';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/tags', label: 'Tags' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(`${href}/`);
---

<header class="site-header">
  <div class="container nav-shell">
    <a class="brand" href="/" aria-label="Kirin Blog home">
      <span class="brand-mark">K</span>
      <span>Kirin Blog</span>
    </a>

    <nav class="nav-links" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a class:list={['nav-link', { active: isActive(item.href) }]} href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="nav-actions" aria-label="Header actions">
      <button type="button" aria-label="Search" title="Search">
        <Search size={23} stroke-width={2.25} />
      </button>
      <button type="button" aria-label="Toggle color theme" title="Theme">
        <Sun size={22} stroke-width={2.2} />
      </button>
      <a href="https://github.com/" aria-label="Code profile" title="Code">
        <CodeXml size={22} stroke-width={2.3} />
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    z-index: 10;
    top: 0;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(18px);
  }

  .nav-shell {
    display: grid;
    min-height: 78px;
    align-items: center;
    grid-template-columns: 1fr auto 1fr;
    gap: 20px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    justify-self: start;
    font-size: 1.15rem;
    font-weight: 850;
  }

  .brand-mark {
    display: inline-grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 10px 24px rgba(25, 31, 48, 0.06);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: clamp(18px, 3vw, 42px);
    justify-self: center;
  }

  .nav-link {
    position: relative;
    padding: 28px 0 24px;
    color: #202635;
    font-size: 0.96rem;
    font-weight: 700;
  }

  .nav-link::after {
    position: absolute;
    right: 0;
    bottom: 10px;
    left: 0;
    height: 3px;
    border-radius: 999px;
    background: var(--accent);
    content: "";
    opacity: 0;
    transform: scaleX(0.5);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .nav-link.active::after,
  .nav-link:hover::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-self: end;
  }

  .nav-actions a,
  .nav-actions button {
    display: inline-grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 0;
    background: transparent;
    color: #080b12;
    cursor: pointer;
  }

  @media (max-width: 900px) {
    .nav-shell {
      grid-template-columns: 1fr auto;
      padding: 12px 0;
    }

    .nav-links {
      width: 100%;
      overflow-x: auto;
      grid-column: 1 / -1;
      grid-row: 2;
      justify-content: flex-start;
      padding-bottom: 4px;
      scrollbar-width: none;
    }

    .nav-links::-webkit-scrollbar {
      display: none;
    }

    .nav-link {
      padding: 8px 0 12px;
      white-space: nowrap;
    }

    .nav-link::after {
      bottom: 2px;
    }

    .nav-actions {
      gap: 8px;
    }
  }

  @media (max-width: 520px) {
    .brand {
      gap: 10px;
      font-size: 1rem;
    }

    .brand-mark {
      width: 36px;
      height: 36px;
    }

    .nav-actions {
      gap: 2px;
    }

    .nav-actions button:nth-of-type(2),
    .nav-actions a {
      display: none;
    }
  }
</style>
