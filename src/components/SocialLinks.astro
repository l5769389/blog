---
import { Mail } from '@lucide/astro';
import GitHubIcon from './GitHubIcon.astro';

const links = [
  { href: 'https://github.com/l5769389', label: 'GitHub home', Icon: GitHubIcon },
  { href: 'mailto:5769389@qq.com', label: 'Email Kirin', Icon: Mail },
];
---

<div class="social-links" aria-label="Social links">
  {
    links.map(({ href, label, Icon }) => (
      <a href={href} aria-label={label} title={label}>
        <Icon size={25} />
      </a>
    ))
  }
</div>

<style>
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
    margin-top: 30px;
  }

  .social-links a {
    display: inline-grid;
    width: 30px;
    height: 30px;
    place-items: center;
    color: var(--icon-color);
  }
</style>
