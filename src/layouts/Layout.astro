---
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kirin Works',
  description = 'A portfolio and project journal for Kirin.',
} = Astro.props;

const pageTitle = title === 'Kirin Works' ? title : `${title} | Kirin Works`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const fallbackTheme = 'light';

        try {
          const savedTheme = localStorage.getItem('theme');
          const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
          const theme =
            savedTheme === 'dark' || savedTheme === 'light' ? savedTheme : systemTheme;

          document.documentElement.dataset.theme = theme;
        } catch {
          document.documentElement.dataset.theme = fallbackTheme;
        }

        try {
          const savedLang = localStorage.getItem('lang');
          const lang = savedLang === 'en' || savedLang === 'zh' ? savedLang : 'zh';

          document.documentElement.dataset.lang = lang;
          document.documentElement.lang = lang === 'en' ? 'en' : 'zh-CN';
        } catch {
          document.documentElement.dataset.lang = 'zh';
          document.documentElement.lang = 'zh-CN';
        }
      })();
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <script is:inline>
      (() => {
        const langKey = 'lang';
        const getLang = () => (document.documentElement.dataset.lang === 'en' ? 'en' : 'zh');

        const setLocalizedAttribute = (element, attr, lang) => {
          const value = element.getAttribute(`data-i18n-${attr}-${lang}`);

          if (value !== null) {
            element.setAttribute(attr, value);
          }
        };

        const applyLanguage = () => {
          const lang = getLang();

          document.documentElement.lang = lang === 'en' ? 'en' : 'zh-CN';

          document.querySelectorAll('[data-i18n-zh][data-i18n-en]').forEach((element) => {
            const value = element.getAttribute(`data-i18n-${lang}`);

            if (value !== null) {
              element.textContent = value;
            }
          });

          document.querySelectorAll('[data-i18n-title-zh][data-i18n-title-en]').forEach((element) => {
            setLocalizedAttribute(element, 'title', lang);
          });

          document.querySelectorAll('[data-i18n-aria-label-zh][data-i18n-aria-label-en]').forEach((element) => {
            setLocalizedAttribute(element, 'aria-label', lang);
          });
        };

        document.addEventListener('click', (event) => {
          const button = event.target instanceof Element
            ? event.target.closest('[data-lang-toggle]')
            : null;

          if (!(button instanceof HTMLButtonElement)) {
            return;
          }

          const nextLang = getLang() === 'en' ? 'zh' : 'en';
          document.documentElement.dataset.lang = nextLang;

          try {
            localStorage.setItem(langKey, nextLang);
          } catch {
            // The visible page still updates even when localStorage is unavailable.
          }

          applyLanguage();
        });

        applyLanguage();
      })();
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f8fb;
    --surface: #ffffff;
    --surface-soft: #f3f6fb;
    --text: #0d111b;
    --muted: #5f6675;
    --line: #dfe4ec;
    --line-strong: #cbd4e1;
    --accent: #5b63f1;
    --accent-strong: #3f46d8;
    --green: #2f7d4c;
    --rose: #c2566f;
    --shadow: 0 18px 45px rgba(32, 38, 58, 0.08);
    --shadow-soft: 0 14px 36px rgba(25, 31, 48, 0.05);
    --card-shadow: 0 10px 30px rgba(25, 31, 48, 0.04);
    --button-shadow: 0 10px 22px rgba(25, 31, 48, 0.04);
    --primary-shadow: 0 14px 28px rgba(91, 99, 241, 0.22);
    --body-bg:
      radial-gradient(circle at top left, rgba(91, 99, 241, 0.06), transparent 34rem),
      linear-gradient(180deg, #ffffff 0, #f7f8fb 34rem);
    --header-bg: rgba(255, 255, 255, 0.92);
    --footer-bg: rgba(255, 255, 255, 0.8);
    --hero-bg: rgba(255, 255, 255, 0.64);
    --home-bg: rgba(255, 255, 255, 0.76);
    --article-bg: rgba(255, 255, 255, 0.72);
    --brand-bg: #ffffff;
    --tag-bg: #ffffff;
    --tag-text: #4c5362;
    --link-muted: #424857;
    --nav-text: #202635;
    --icon-color: #080b12;
    --content-text: #273040;
    --meta-text: #5d6575;
    --meta-divider: #9ca4b4;
    --cover-border: #edf0f5;
    --cover-typescript-bg:
      radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.9), transparent 180px),
      linear-gradient(135deg, #d5c9ff, #dcefff 70%);
    --cover-architecture-bg: linear-gradient(135deg, #ecf4ff, #f8fbff);
    --cover-growth-bg:
      radial-gradient(circle at 55% 55%, rgba(72, 146, 77, 0.14), transparent 110px),
      linear-gradient(135deg, #f7fbef, #deede0);
    --cover-astro-bg:
      radial-gradient(circle at 28% 24%, rgba(194, 86, 111, 0.16), transparent 170px),
      linear-gradient(135deg, #eef0ff, #fff7f3);
    --cover-dicom-bg:
      linear-gradient(135deg, rgba(13, 17, 27, 0.96), rgba(36, 48, 72, 0.96)),
      linear-gradient(90deg, rgba(91, 99, 241, 0.28), rgba(47, 125, 76, 0.2));
    --cover-respira-bg:
      radial-gradient(circle at 20% 24%, rgba(47, 125, 76, 0.18), transparent 170px),
      linear-gradient(135deg, #e8f7ef, #eef5ff);
    --cover-note-bg:
      radial-gradient(circle at 24% 22%, rgba(91, 99, 241, 0.14), transparent 170px),
      linear-gradient(135deg, #f3f7ff, #eef8f1);
    --radius: 8px;
    color-scheme: light;
  }

  html[data-theme='dark'] {
    --bg: #0a0d12;
    --surface: #111720;
    --surface-soft: #171f2b;
    --text: #eef3fb;
    --muted: #a7b0bf;
    --line: #283241;
    --line-strong: #3a4658;
    --accent: #8992ff;
    --accent-strong: #b4bbff;
    --green: #76d39c;
    --rose: #f090aa;
    --shadow: 0 18px 45px rgba(0, 0, 0, 0.32);
    --shadow-soft: 0 14px 36px rgba(0, 0, 0, 0.24);
    --card-shadow: 0 12px 32px rgba(0, 0, 0, 0.22);
    --button-shadow: 0 12px 26px rgba(0, 0, 0, 0.22);
    --primary-shadow: 0 14px 30px rgba(137, 146, 255, 0.18);
    --body-bg:
      linear-gradient(180deg, rgba(18, 22, 30, 0.96) 0, rgba(10, 13, 18, 1) 38rem),
      #0a0d12;
    --header-bg: rgba(12, 16, 23, 0.9);
    --footer-bg: rgba(13, 18, 26, 0.84);
    --hero-bg: rgba(15, 20, 29, 0.68);
    --home-bg: rgba(13, 18, 26, 0.72);
    --article-bg: rgba(13, 18, 26, 0.72);
    --brand-bg: #151c27;
    --tag-bg: #171f2b;
    --tag-text: #c9d2df;
    --link-muted: #c6cfde;
    --nav-text: #dce4f0;
    --icon-color: #eef3fb;
    --content-text: #d9e1ec;
    --meta-text: #aeb8c8;
    --meta-divider: #667286;
    --cover-border: #263141;
    --cover-typescript-bg:
      linear-gradient(135deg, rgba(66, 72, 142, 0.74), rgba(25, 55, 80, 0.9));
    --cover-architecture-bg: linear-gradient(135deg, #172232, #111720);
    --cover-growth-bg:
      radial-gradient(circle at 55% 55%, rgba(118, 211, 156, 0.18), transparent 110px),
      linear-gradient(135deg, #111d18, #1a2a21);
    --cover-astro-bg:
      radial-gradient(circle at 28% 24%, rgba(240, 144, 170, 0.18), transparent 170px),
      linear-gradient(135deg, #141829, #261924);
    --cover-dicom-bg:
      linear-gradient(135deg, rgba(7, 10, 15, 0.98), rgba(22, 33, 49, 0.98)),
      linear-gradient(90deg, rgba(137, 146, 255, 0.28), rgba(118, 211, 156, 0.2));
    --cover-respira-bg:
      radial-gradient(circle at 20% 24%, rgba(118, 211, 156, 0.18), transparent 170px),
      linear-gradient(135deg, #0f1d19, #141d2a);
    --cover-note-bg:
      radial-gradient(circle at 24% 22%, rgba(137, 146, 255, 0.18), transparent 170px),
      linear-gradient(135deg, #111827, #14211c);
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  body {
    min-width: 320px;
    margin: 0;
    background: var(--body-bg);
  }

  body,
  button,
  input {
    font: inherit;
  }

  button {
    color: inherit;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  svg {
    display: block;
  }

  main {
    min-height: calc(100vh - 160px);
  }

  .container {
    width: min(100% - 40px, 1320px);
    margin-inline: auto;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .eyebrow strong {
    color: var(--accent);
    font-weight: 800;
  }

  .section-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 20px;
  }

  .section-heading h2,
  .section-heading h1 {
    margin: 0;
    font-size: clamp(1.35rem, 1.2rem + 0.55vw, 1.8rem);
    line-height: 1.15;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--link-muted);
    font-weight: 650;
    white-space: nowrap;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 26px;
  }

  .button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    gap: 9px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0 24px;
    background: var(--surface);
    color: var(--text);
    font-weight: 750;
    box-shadow: var(--button-shadow);
  }

  .button.primary {
    border-color: transparent;
    background: var(--accent);
    color: white;
    box-shadow: var(--primary-shadow);
  }

  .tag {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 10px;
    background: var(--tag-bg);
    color: var(--tag-text);
    font-size: 0.84rem;
    font-weight: 650;
  }

  .page-shell {
    padding: 58px 0 72px;
  }

  .page-header {
    max-width: 780px;
    margin-bottom: 34px;
  }

  .page-header h1 {
    margin: 0 0 14px;
    font-size: clamp(2.1rem, 1.65rem + 2vw, 4.1rem);
    line-height: 1.02;
    letter-spacing: 0;
  }

  .page-header p {
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .grid {
    display: grid;
    gap: 22px;
  }

  @media (max-width: 760px) {
    .container {
      width: min(100% - 28px, 1320px);
    }

    .page-shell {
      padding-top: 38px;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .button {
      width: 100%;
    }

  }
</style>
