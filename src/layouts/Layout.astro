---
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kirin Blog',
  description = 'A personal blog about code, products, and learning in public.',
} = Astro.props;

const pageTitle = title === 'Kirin Blog' ? title : `${title} | Kirin Blog`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <p>© 2026 Kirin Blog</p>
        <a href="/blog">All posts</a>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f8fb;
    --surface: #ffffff;
    --surface-soft: #f3f6fb;
    --text: #0d111b;
    --muted: #5f6675;
    --line: #dfe4ec;
    --line-strong: #cbd4e1;
    --accent: #5b63f1;
    --accent-strong: #3f46d8;
    --green: #2f7d4c;
    --rose: #c2566f;
    --shadow: 0 18px 45px rgba(32, 38, 58, 0.08);
    --radius: 8px;
    color-scheme: light;
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  body {
    min-width: 320px;
    margin: 0;
    background:
      radial-gradient(circle at top left, rgba(91, 99, 241, 0.06), transparent 34rem),
      linear-gradient(180deg, #ffffff 0, #f7f8fb 34rem);
  }

  body,
  button,
  input {
    font: inherit;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  svg {
    display: block;
  }

  main {
    min-height: calc(100vh - 160px);
  }

  .container {
    width: min(100% - 40px, 1320px);
    margin-inline: auto;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .eyebrow strong {
    color: var(--accent);
    font-weight: 800;
  }

  .section-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 20px;
  }

  .section-heading h2,
  .section-heading h1 {
    margin: 0;
    font-size: clamp(1.35rem, 1.2rem + 0.55vw, 1.8rem);
    line-height: 1.15;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #424857;
    font-weight: 650;
    white-space: nowrap;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 26px;
  }

  .button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    gap: 9px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0 24px;
    background: var(--surface);
    color: var(--text);
    font-weight: 750;
    box-shadow: 0 10px 22px rgba(25, 31, 48, 0.04);
  }

  .button.primary {
    border-color: transparent;
    background: var(--accent);
    color: white;
    box-shadow: 0 14px 28px rgba(91, 99, 241, 0.22);
  }

  .tag {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 6px 10px;
    background: #fff;
    color: #4c5362;
    font-size: 0.84rem;
    font-weight: 650;
  }

  .page-shell {
    padding: 58px 0 72px;
  }

  .page-header {
    max-width: 780px;
    margin-bottom: 34px;
  }

  .page-header h1 {
    margin: 0 0 14px;
    font-size: clamp(2.1rem, 1.65rem + 2vw, 4.1rem);
    line-height: 1.02;
    letter-spacing: 0;
  }

  .page-header p {
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .grid {
    display: grid;
    gap: 22px;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.8);
  }

  .footer-inner {
    display: flex;
    min-height: 76px;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .footer-inner p {
    margin: 0;
  }

  @media (max-width: 760px) {
    .container {
      width: min(100% - 28px, 1320px);
    }

    .page-shell {
      padding-top: 38px;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .button {
      width: 100%;
    }

    .footer-inner {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      padding: 18px 0;
    }
  }
</style>
